{
  "monorepo": true,
  "root": "apps/main",
  "sourceRoot": "apps/main/src",
  "compilerOptions": {
    "webpack": true,
    "tsConfigPath": "apps/main/tsconfig.app.json"
  },
  "projects": {
    "hoteles": {
      "type": "application",
      "root": "apps/hoteles",
      "entryFile": "main",
      "sourceRoot": "apps/hoteles/src",
      "compilerOptions": {
        "tsConfigPath": "apps/hoteles/tsconfig.app.json"
      }
    },
    "main": {
      "type": "application",
      "root": "apps/main",
      "entryFile": "main",
      "sourceRoot": "apps/main/src",
      "compilerOptions": {
        "tsConfigPath": "apps/main/tsconfig.app.json"
      }
    },
    "usuarios": {
      "type": "application",
      "root": "apps/usuarios",
      "entryFile": "main",
      "sourceRoot": "apps/usuarios/src",
      "compilerOptions": {
        "tsConfigPath": "apps/usuarios/tsconfig.app.json"
      }
    }
  }
}